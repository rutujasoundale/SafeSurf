{
  "manifest_version": 3,
  "name": "SafeSurf",
  "version": "1.0",

  "permissions": [
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "scripts/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}